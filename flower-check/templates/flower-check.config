# flower-check host project config.
#
# Put this file at the host project's repository root and run `mvn verify`
# through flower-check-maven-plugin.

# Strict default. Keep this at error unless the project intentionally wants
# WARNING findings to fail the build too.
failOn: error

# Tier 2 agent-runtime rules are opt-in because not every Flower user has an
# agent/action layer.
agentRulesEnabled: false

# The official scheduler approval annotation is already built in. Keep the
# section here so project-local aliases are explicit in code review.
schedulerApprovalAnnotations:
  - FlowerSchedulerApproved
  # - UserApprovedScheduler
  # - SchedulerApproved

# Enable this only during controlled adoption. The file must exist during a
# normal failing check run.
# baselineFile: flower-check-baseline.txt

# Add project-specific Step base classes when domain Steps inherit from a local
# abstract class instead of directly extending Flower's Step/DurableStep.
# stepBaseClasses:
#   - com.acme.flow.AbstractDomainStep

# Add project-specific LLM/provider client type names when FLOWER-CHECK-002
# should catch direct model calls through local wrappers.
# providerClientNames:
#   - com.acme.llm.OpenAiClient

# Disabling rules should be rare and reviewed. Prefer a baseline for existing
# debt or an inline suppression for one justified site.
# rules:
#   FLOWER-CHECK-004: warning
#   FLOWER-CHECK-007: off
